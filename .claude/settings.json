{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{ f=$(jq -r '.tool_response.filePath // .tool_input.file_path'); [ -f \"$f\" ] || exit 0; case \"$f\" in *.ts|*.tsx|*.js|*.jsx) pnpm exec eslint --fix --no-warn-ignored \"$f\" >/dev/null 2>&1 ;; *.css) pnpm exec stylelint --fix \"$f\" >/dev/null 2>&1 ;; esac; pnpm exec prettier --write --ignore-unknown \"$f\" >/dev/null 2>&1; } || true",
            "timeout": 60,
            "statusMessage": "Formatting & linting..."
          }
        ]
      }
    ]
  }
}
